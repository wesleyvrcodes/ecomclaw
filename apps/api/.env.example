# ===========================================
# EcomClaw API — Environment Variables
# Copy to .env and fill in real values
# ===========================================

# JWT Authentication (required — 64+ character random string)
JWT_SECRET=

# Database (required — PostgreSQL connection string)
CONNECTION_STRING=Host=localhost;Port=5432;Database=clawcommerce;Username=postgres;Password=changeme

# URLs
API_BASE_URL=http://localhost:5001
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# Encryption (generate with: openssl rand -base64 32)
ENCRYPTION_MASTER_KEY=

# Hetzner VPS Provisioning
HETZNER_MOCK_MODE=true
HETZNER_API_TOKEN=
HETZNER_LOCATION=nbg1
HETZNER_SERVER_TYPE=cx22
HETZNER_SSH_KEY_NAME=
HETZNER_FIREWALL_ID=
HETZNER_AGENT_IMAGE=ghcr.io/ecomclaw/openclaw-agent:latest

# Cloudflare Tunnel
CLOUDFLARE_MOCK_MODE=true
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_TUNNEL_DOMAIN=agents.ecomclaw.com

# Stripe Billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_STARTER=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_BUSINESS=

# Admin Access (comma-separated emails)
ADMIN_EMAILS=
